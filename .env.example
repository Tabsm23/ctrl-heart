# Copy to .env and fill in values. Vite only exposes variables prefixed with VITE_.

# Supabase: Dashboard → Project Settings → API → Project URL & anon public key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (optional for checkout links)
# VITE_STRIPE_PUBLISHABLE_KEY=
# VITE_STRIPE_PAYMENT_LINK_1MONTH=
# VITE_STRIPE_PAYMENT_LINK_3MONTH=
# VITE_STRIPE_PAYMENT_LINK_6MONTH=
